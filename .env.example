# Stock Review Alpha Assistant - Environment Variables
# Copy this file to .env and fill in your actual values

# LLM provider: anthropic | kimi | minimax | openai_compatible
LLM_PROVIDER=minimax

# Minimax OpenAI-compatible API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_PROTOCOL=anthropic
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_MIN_OUTPUT_TOKENS=2000

# Claude fallback/alternative
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Rollbar (error tracking)
# Sign up at https://rollbar.com, create a project, copy the post_server_item token
ROLLBAR_ACCESS_TOKEN=your_rollbar_post_server_token_here

# Database path (optional, defaults to data/portfolio.db)
DATABASE_URL=sqlite:///data/portfolio.db

# Environment (development | staging | production)
ENVIRONMENT=development
